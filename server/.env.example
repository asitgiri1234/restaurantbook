# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Local: mongodb://127.0.0.1:27017/restaurantbook
# Atlas: mongodb+srv://<user>:<pass>@<cluster>/restaurantbook?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/restaurantbook

# --- Auth ---
# Use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173

# --- Seed admin (used by `npm run seed`) ---
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@restaurantbook.com
ADMIN_PASSWORD=Admin@123
